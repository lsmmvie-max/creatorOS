# Pre-push hook: mirrors CI "Quality Checks" (fast subset)
# Skip with: git push --no-verify

# Resolve editor root and vp binary with absolute paths
SCRIPT_DIR="$(dirname "$0")"
EDITOR_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
VP="$EDITOR_ROOT/node_modules/.bin/vp"
cd "$EDITOR_ROOT"

set -e

echo "Running quality checks before push..."

echo "  [1/7] check:boundaries"
"$VP" run check:boundaries --silent

echo "  [2/7] check:deps-contracts"
"$VP" run check:deps-contracts --silent

echo "  [3/7] check:legacy-lib-imports"
"$VP" run check:legacy-lib-imports --silent

echo "  [4/7] check:deps-wrapper-health"
"$VP" run check:deps-wrapper-health --silent

echo "  [5/7] check:changed-health"
FALLOW_AUDIT_BASE=origin/main "$VP" run check:changed-health

echo "  [6/7] check:edge-budgets"
EDGE_REPORT=$(mktemp)
trap 'rm -f "$EDGE_REPORT"' EXIT
node scripts/report-feature-edges.mjs --json > "$EDGE_REPORT"
node scripts/check-feature-edge-budgets.mjs --input "$EDGE_REPORT"

echo "  [7/7] check"
"$VP" run check --silent

echo "All quality checks passed."
